# OmniForge AI Environment Configuration
# Copy this file to .env and replace placeholders with your keys.
# Keys can also be configured in-app via Settings > API Keys.

APP_NAME=OmniForge AI
APP_VERSION=1.0.0
ENVIRONMENT=development

# Default providers per task
DEFAULT_CHAT_PROVIDER=openai
DEFAULT_IMAGE_PROVIDER=openai
DEFAULT_VIDEO_PROVIDER=runway
DEFAULT_MUSIC_PROVIDER=suno

# Provider base URLs (override only if using proxies)
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GROK_BASE_URL=https://api.x.ai/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MISTRAL_BASE_URL=https://api.mistral.ai/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OLLAMA_BASE_URL=http://localhost:11434/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Image provider URLs
STABILITY_BASE_URL=https://api.stability.ai/v1
FLUX_BASE_URL=https://api.bfl.ai
IDEOGRAM_BASE_URL=https://api.ideogram.ai/v1
RECRAFT_BASE_URL=https://external.api.recraft.ai/v1
LEONARDO_BASE_URL=https://cloud.leonardo.ai/api/rest/v1

# Video provider URLs
RUNWAY_BASE_URL=https://api.runwayml.com/v1
PIKA_BASE_URL=https://api.pika.art/v1
LUMA_BASE_URL=https://api.lumalabs.ai/v1
KLING_BASE_URL=https://api.klingai.com/v1
VEO_BASE_URL=https://api.googleapis.com/v1
PIXVERSE_BASE_URL=https://api.pixverse.ai/v1
HAILUO_BASE_URL=https://api.hailuo.ai/v1

# Music provider URLs
SUNO_BASE_URL=https://api.suno.ai/v1
UDIO_BASE_URL=https://api.udio.com/v1

# Analytics (optional)
SENTRY_DSN=
FIREBASE_API_KEY=

# Storage
HIVE_BOX_NAME=omniforge_db
SECURE_STORAGE_KEY=omniforge_secure
ENCRYPTION_SALT=omniforge_salt_v1
